				{
					"name": "User Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract and cache JWT auth token automatically on login success",
									"var jsonData = pm.response.json();",
									"if(jsonData.success && jsonData.token) {",
									"    pm.collectionVariables.set(\"authToken\", jsonData.token);",
									"    console.log(\"Saved jwt token automatically to collection variable [authToken]: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"green.developer@example.com\",\n  \"password\": \"ecotrack123\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/auth/login",
							"protocol": "http",
							"host": [
								"localhost"
							],
