# Server Configuration
PORT=5000

# Database Settings
# Replace with local mongodb string (e.g. mongodb://127.0.0.1:27017/ecotrack) or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/ecotrack

# Authentication Configurations
JWT_SECRET=YOUR_SUPER_SECRET_JWT_SIGNING_KEY_CHOOSE_A_LONG_ONE
JWT_EXPIRES_IN=7d

# Google Gemini AI Config
# Get an API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_AI_STUDIO_API_KEY
